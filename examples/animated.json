{
  "version": "1.0",
  "video": {
    "width": 1080,
    "height": 1920,
    "fps": 30,
    "background": "#0f172a"
  },
  "scenes": [
    {
      "duration": 4.0,
      "layers": [
        {
          "type": "shape",
          "shape": "rounded_rect",
          "position": { "x": 90, "y": 700 },
          "size": { "width": 900, "height": 500 },
          "fill": {
            "type": "linear",
            "colors": ["#3b82f6", "#8b5cf6"],
            "angle": 135
          },
          "corner_radius": 32,
          "preset": "scale_in",
          "preset_config": { "delay": 0.0, "duration": 1.0 }
        },
        {
          "type": "text",
          "content": "Rustmotion",
          "position": { "x": 540, "y": 900 },
          "font_size": 72,
          "color": "#FFFFFF",
          "font_weight": "bold",
          "align": "center",
          "preset": "fade_in_up",
          "preset_config": { "delay": 0.3, "duration": 0.8 }
        },
        {
          "type": "text",
          "content": "Video generation from JSON",
          "position": { "x": 540, "y": 1000 },
          "font_size": 32,
          "color": "#94a3b8",
          "align": "center",
          "preset": "typewriter",
          "preset_config": { "delay": 0.8, "duration": 1.5 }
        },
        {
          "type": "shape",
          "shape": "circle",
          "position": { "x": 390, "y": 1350 },
          "size": { "width": 300, "height": 300 },
          "fill": "#22c55e",
          "preset": "bounce_in",
          "preset_config": { "delay": 1.5, "duration": 1.0 }
        },
        {
          "type": "text",
          "content": "Powered by Rust + Skia",
          "position": { "x": 540, "y": 1750 },
          "font_size": 28,
          "color": "#64748b",
          "align": "center",
          "animations": [
            {
              "property": "opacity",
              "keyframes": [
                { "time": 0, "value": 0 },
                { "time": 2.0, "value": 0 },
                { "time": 3.0, "value": 1 }
              ],
              "easing": "ease_out"
            }
          ]
        }
      ]
    }
  ]
}
